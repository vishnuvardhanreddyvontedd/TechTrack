generator client {
  provider = "prisma-client"
  output   = "../../../apps/web/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  role             UserRole  @default(LEARNER)
  avatarUrl        String?
  xp               Int       @default(0)
  level            Int       @default(1)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  roadmaps         Roadmap[]
  taskCompletions  TaskCompletion[]
  xpTransactions   XPTransaction[]
  userBadges       UserBadge[]
  streaks          Streak[]
  aiConversations  AIConversation[]
  subscriptions    Subscription[]
  notifications    Notification[]
  auditLogs        AuditLog[]        @relation("AuditActor")

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Profile {
  id                    String        @id @default(cuid())
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String        @unique
  skillLevel            SkillLevel?
  careerGoal            String?
  dailyAvailableMinutes Int?
  preferredLearningStyle LearningStyle?
  targetTimelineWeeks   Int?
  existingSkills        String[]      @default([])
  weakAreas             String[]      @default([])
  portfolioUrl          String?
  githubUrl             String?
  linkedinUrl           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([careerGoal])
}

model CareerTrack {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  category    Category
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  roadmaps    Roadmap[]

  @@index([category])
  @@index([isActive])
}

model RoadmapTemplate {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String
  category    Category
  totalDays   Int
  iconEmoji   String        @default("map")
  createdAt   DateTime      @default(now())

  dayTemplates DayTemplate[]
  roadmaps     Roadmap[]
}

model DayTemplate {
  id               String          @id @default(cuid())
  template         RoadmapTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId       String
  dayNumber        Int
  title            String
  description      String
  estimatedMinutes Int             @default(60)
  resources        String[]        @default([])

  tasks            Task[]

  @@unique([templateId, dayNumber])
  @@index([templateId])
}

model Roadmap {
  id             String          @id @default(cuid())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  template       RoadmapTemplate? @relation(fields: [templateId], references: [id])
  templateId     String?
  careerTrack    CareerTrack?    @relation(fields: [careerTrackId], references: [id])
  careerTrackId  String?
  customGoal     String?
  title          String?
  durationDays   Int             @default(30)
  durationWeeks  Int?
  status         RoadmapStatus   @default(ACTIVE)
  isActive       Boolean         @default(true)
  aiProvider     String?
  aiModel        String?
  rawAiOutput    Json?
  startDate      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  phases         RoadmapPhase[]
  tasks          Task[]
  dailyPlans     DailyPlan[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([careerTrackId])
  @@index([status])
  @@index([createdAt])
}

model RoadmapPhase {
  id          String          @id @default(cuid())
  roadmap     Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId   String
  title       String
  description String
  order       Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  modules     RoadmapModule[]

  @@unique([roadmapId, order])
  @@index([roadmapId])
}

model RoadmapModule {
  id          String       @id @default(cuid())
  phase       RoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  phaseId     String
  title       String
  description String?
  order       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tasks       Task[]

  @@unique([phaseId, order])
  @@index([phaseId])
}

model Task {
  id               String          @id @default(cuid())
  roadmap          Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId        String
  module           RoadmapModule?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  moduleId         String?
  dayTemplate      DayTemplate?    @relation(fields: [dayTemplateId], references: [id])
  dayTemplateId    String?
  dayNumber        Int
  customTitle      String?
  customDesc       String?
  estimatedMinutes Int             @default(60)
  type             TaskType        @default(LEARNING)
  status           TaskStatus      @default(PENDING)
  xpReward         Int             @default(50)
  isComplete       Boolean         @default(false)
  completedAt      DateTime?
  xpAwarded        Int             @default(0)
  resources        String[]        @default([])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  dailyPlanTasks   DailyPlanTask[]
  completions      TaskCompletion[]

  @@index([roadmapId])
  @@index([moduleId])
  @@index([roadmapId, isComplete])
  @@index([status])
  @@index([createdAt])
}

model TaskCompletion {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  xpAwarded   Int       @default(0)
  completedAt DateTime  @default(now())
  notes       String?

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@index([completedAt])
}

model XPTransaction {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  amount      Int
  reason      String
  sourceType  String?
  sourceId    String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String
  iconName    String      @default("award")
  xpBonus     Int         @default(0)
  createdAt   DateTime    @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Streak {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  count     Int      @default(0)
  startedAt DateTime @default(now())
  endedAt   DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DailyPlan {
  id          String     @id @default(cuid())
  roadmap     Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId   String
  date        DateTime
  plannedDay  Int
  status      PlanStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       DailyPlanTask[]

  @@unique([roadmapId, date])
  @@index([roadmapId, date])
  @@index([roadmapId, status])
}

model DailyPlanTask {
  id          String    @id @default(cuid())
  dailyPlan   DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  dailyPlanId String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  isCarryover Boolean   @default(false)

  @@unique([dailyPlanId, taskId])
  @@index([dailyPlanId])
}

model AIConversation {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String?
  type      AIAgentType @default(MENTOR)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  messages  AIMessage[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           AIMessageRole
  content        String
  model          String?
  tokenCount     Int?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model AdminPrompt {
  id          String      @id @default(cuid())
  key         String      @unique
  title       String
  content     String
  agentType   AIAgentType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([agentType])
  @@index([isActive])
}

model Subscription {
  id          String             @id @default(cuid())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  provider    String             @default("razorpay")
  plan        String             @default("free")
  status      SubscriptionStatus @default(FREE)
  providerRef String?
  startedAt   DateTime?
  endsAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum UserRole {
  LEARNER
  ADMIN
  MENTOR
  ORG_ADMIN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearningStyle {
  READING
  VIDEO
  PROJECT_BASED
  MIXED
}

enum Category {
  FRONTEND
  BACKEND
  FULLSTACK
  AI_ML
  DEVOPS
  MOBILE
  DATA_SCIENCE
  CYBERSECURITY
  DESIGN
  PRODUCT
}

enum RoadmapStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskType {
  LEARNING
  CODING
  QUIZ
  PROJECT
  INTERVIEW
  PORTFOLIO
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum AIAgentType {
  ROADMAP
  MENTOR
  INTERVIEW
  RESUME
  GITHUB_REVIEW
  PROGRESS
  JOB
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum NotificationType {
  TASK_REMINDER
  STREAK
  BADGE
  LEVEL_UP
  SYSTEM
}
