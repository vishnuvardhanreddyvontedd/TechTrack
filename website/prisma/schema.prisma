// Prisma Schema — TechTrack
// generator outputs to app/generated/prisma (Prisma 6 default)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  avatarUrl        String?   // URL to stored profile picture in Supabase
  xp               Int       @default(0)
  level            Int       @default(1)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  roadmaps         Roadmap[]

  @@index([email])
}

// ─── Roadmap Templates (seeded, static) ─────────────────────────────────────

model RoadmapTemplate {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String
  category    Category
  totalDays   Int
  iconEmoji   String        @default("🗺️")
  createdAt   DateTime      @default(now())

  dayTemplates DayTemplate[]
  roadmaps     Roadmap[]
}

model DayTemplate {
  id               String          @id @default(cuid())
  template         RoadmapTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId       String
  dayNumber        Int
  title            String
  description      String
  estimatedMinutes Int             @default(60)
  resources        String[]        @default([])

  tasks            Task[]

  @@unique([templateId, dayNumber])
  @@index([templateId])
}

// ─── User Roadmap Instances ───────────────────────────────────────────────────

model Roadmap {
  id          String           @id @default(cuid())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  // Template-based roadmaps (predefined)
  template    RoadmapTemplate? @relation(fields: [templateId], references: [id])
  templateId  String?
  // Custom AI-generated roadmaps
  customGoal  String?          // User's raw goal input e.g. "Get a job at Google"
  title       String?          // Display title (from AI or template)
  durationDays Int             @default(30)
  isActive    Boolean          @default(true)
  startDate   DateTime         @default(now())
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tasks       Task[]
  dailyPlans  DailyPlan[]

  @@index([userId])
  @@index([userId, isActive])
}

model Task {
  id            String       @id @default(cuid())
  roadmap       Roadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId     String
  // Template-based task reference (null for AI-generated tasks)
  dayTemplate   DayTemplate? @relation(fields: [dayTemplateId], references: [id])
  dayTemplateId String?
  dayNumber     Int
  // Custom task content (used when dayTemplateId is null)
  customTitle   String?
  customDesc    String?
  estimatedMinutes Int       @default(60)
  isComplete    Boolean      @default(false)
  completedAt   DateTime?
  xpAwarded     Int          @default(0)
  createdAt     DateTime     @default(now())

  dailyPlanTasks DailyPlanTask[]

  @@index([roadmapId])
  @@index([roadmapId, isComplete])
}

// ─── Daily Planning Engine ────────────────────────────────────────────────────
// DailyPlan anchors a calendar date to a set of tasks for a roadmap.
// This is the core of the smart rescheduling system.

model DailyPlan {
  id          String     @id @default(cuid())
  roadmap     Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId   String
  // Calendar date (stored as UTC midnight)
  date        DateTime
  // Which day of the roadmap curriculum this plan covers
  plannedDay  Int
  status      PlanStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       DailyPlanTask[]

  @@unique([roadmapId, date])
  @@index([roadmapId, date])
  @@index([roadmapId, status])
}

// Join table: which tasks are assigned to a given daily plan
model DailyPlanTask {
  id          String    @id @default(cuid())
  dailyPlan   DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  dailyPlanId String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  // True if this task was carried over from a previous day
  isCarryover Boolean   @default(false)

  @@unique([dailyPlanId, taskId])
  @@index([dailyPlanId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Category {
  FRONTEND
  BACKEND
  FULLSTACK
  AI_ML
  DEVOPS
  MOBILE
  DATA_SCIENCE
}

enum PlanStatus {
  PENDING      // Day hasn't started yet
  IN_PROGRESS  // User has completed at least one task today
  COMPLETED    // All tasks done for the day
  SKIPPED      // Day passed with no tasks completed
}
